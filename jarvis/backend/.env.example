# ==================== JARVIS AI Configuration ====================
# Copy this file to .env and fill in your values
# ================================================================

# ==================== Application ====================
APP_NAME=JARVIS AI
VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ==================== Operation Mode ====================
# Options: auto, online, offline
# - auto: Automatically switch based on connectivity
# - online: Force online mode (requires API keys)
# - offline: Force offline mode (uses local models only)
OPERATION_MODE=auto

# Connectivity check settings (for auto mode)
CONNECTIVITY_CHECK_URL=https://www.google.com
CONNECTIVITY_TIMEOUT=5

# ==================== Database ====================
# PostgreSQL for online mode
DATABASE_URL=postgresql://jarvis:jarvis@localhost:5432/jarvis

# SQLite for offline mode (automatically used when offline)
DATABASE_URL_OFFLINE=sqlite:///./jarvis_offline.db

# Redis for caching (online mode only)
REDIS_URL=redis://localhost:6379/0

# ==================== Authentication ====================
# CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== AI Models - Online ====================
# Get your API key from https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Get your API key from https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=your-preferred-voice-id

# Get your API key from https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp

# ==================== AI Models - Offline ====================
# Ollama must be running locally (https://ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Whisper model for local speech-to-text
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base

# Piper TTS for local text-to-speech (optional)
PIPER_TTS_ENABLED=false
PIPER_TTS_VOICE=en_US-lessac-medium

# ==================== Vector Database ====================
# Options: chromadb, pinecone
# chromadb is used by default for offline support
VECTOR_DB_PROVIDER=chromadb
CHROMA_DB_PATH=./chroma_db

# ==================== CORS ====================
# Add your frontend URLs here
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:3000","http://127.0.0.1:8080","http://localhost:5173"]

# ==================== WebSocket ====================
WS_MAX_MESSAGE_SIZE=10485760
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# ==================== Automation ====================
AUTOMATION_ENABLED=true
AUTOMATION_SAFE_MODE=true

# ==================== Storage ====================
# Options: local, s3, firebase
STORAGE_PROVIDER=local
STORAGE_PATH=./storage

# AWS S3 (only if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=jarvis-storage
AWS_REGION=us-east-1

# ==================== Features ====================
FEATURE_AGENTS=true
FEATURE_PLUGINS=true
FEATURE_BROWSER_AUTOMATION=true
FEATURE_VOICE=true
FEATURE_VISION=true

# ==================== Rate Limiting ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ==================== Monitoring ====================
ENABLE_METRICS=true
ENABLE_TRACING=false
